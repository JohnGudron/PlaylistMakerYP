<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.media.activity.FavoriteTracksFragment"
    android:orientation="vertical"
    >

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/favorite_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:layout_marginTop="20dp"
        />

    <ImageView
        android:id="@+id/empty_favorite_img"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_nothing_found_120"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="106dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/empty_favorite_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your media library is empty"
        style="@style/BadResponseTextStyle"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        />

</LinearLayout>