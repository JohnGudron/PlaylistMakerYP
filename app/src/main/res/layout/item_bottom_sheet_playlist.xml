<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/poster_img"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="13dp"
        android:scaleType="center"
        android:src="@drawable/ic_poster_placeholder_312"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/roundedImageViewMini"/>

    <TextView
        android:id="@+id/playlist_name_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/ys_display_regular"
        android:text="@string/playlist_name"
        android:textColor="@color/favorite_icon_tint"
        android:textSize="16sp"
        app:layout_constraintStart_toEndOf="@id/poster_img"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/playlist_size_tv"
        app:layout_constraintVertical_chainStyle="packed"
        />

    <TextView
        android:id="@+id/playlist_size_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/ys_display_regular"
        android:text="@string/playlist_size"
        android:textColor="@color/track_arrow_color"
        android:textSize="11sp"
        app:layout_constraintStart_toEndOf="@id/poster_img"
        app:layout_constraintTop_toBottomOf="@id/playlist_name_tv"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>